# Swaylock Configuration
# Beautiful lock screen with blurred background

# Background
image=~/.config/backgrounds/blurry-snaky.jpg
scaling=fill

# General appearance
color=1e1e2e
font=SpaceMono Nerd Font
font-size=24

# Ring colors (Catppuccin Mocha inspired) - Made more visible
ring-color=89b4fa
ring-clear-color=a6e3a1
ring-caps-lock-color=f9e2af
ring-ver-color=cba6f7
ring-wrong-color=f38ba8

# Key highlight colors
key-hl-color=cba6f7
bs-hl-color=f38ba8

# Separator color
separator-color=00000000

# Inside colors - Less transparent for better visibility
inside-color=1e1e2ecc
inside-clear-color=1e1e2ecc
inside-caps-lock-color=1e1e2ecc
inside-ver-color=1e1e2ecc
inside-wrong-color=1e1e2ecc

# Text colors
text-color=cdd6f4
text-clear-color=1e1e2e
text-caps-lock-color=1e1e2e
text-ver-color=1e1e2e
text-wrong-color=1e1e2e

# Layout
indicator-radius=120
indicator-thickness=8
indicator-caps-lock

# Show indicator immediately (not just when typing)
show-keyboard-layout
no-unlock-indicator=false

# Effects
effect-blur=7x5
effect-vignette=0.5:0.5
fade-in=0.2

# Clock and text indicators
clock
timestr=%H:%M
datestr=%A, %d %B %Y

# Text indicators for better UX
text-ver-color=89b4fa
text-wrong-color=f38ba8
text-clear-color=a6e3a1
text-caps-lock-color=f9e2af

# Show helpful text
verifying-text="Verifying..."
wrong-text="Wrong Password!"
clear-text="Password Cleared"
caps-lock-text="Caps Lock On"

# Password input behavior
show-failed-attempts
