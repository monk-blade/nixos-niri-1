{
    "layer": "bottom",
    "position": "bottom",
    "height": 22,
    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": [""],
    "modules-right": [
        // "custom/night_mode",
        // "custom/power"
        "niri/language",
        "custom/updates",
        // "memory",
        // "cpu",
        // "disk",
        "pulseaudio",
        "pulseaudio#microphone",
        "backlight",
        "battery",
        "custom/weather",
        "custom/prayer",
        "clock",
        "tray"
    ],
    "niri/workspaces": {
        "format": "{name}"
    },
    "niri/window": {
        "format": "{title}",
        "max-length": 50
    },
    "network": {
        "format-wifi": "σΑΛ® {bandwidthUpBytes} σΑΛΞ {bandwidthDownBytes}",
        "format-ethernet": "σΑàÄ {bandwidthUpBytes} σΑΛΞ {bandwidthDownBytes}",
        "format-disconnected": "σΑΛ≠ Disconnected",
        "interval": 2,
        "tooltip-format": "{ifname}: {ipaddr}"
    },
    "memory": {
        "format": "σΑç¦ {percentage}%",
        "interval": 5
    },
    "cpu": {
        "format": "σΑΜ† {usage}%",
        "interval": 5
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü",
        "format-icons": {
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "pavucontrol"
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "σΑç§ {volume}%",
        "format-source-muted": "σΑç≠",
        "on-click": "pavucontrol"
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"]
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "format-charging": "σΑ²³ {capacity}%",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        }
    },
    "custom/night_mode": {
        "format": "{}",
        "exec": "echo 'σ±©¨' NL",
        "on-click": "wlsunset -t 4500 -T 6500",
        "on-click-right": "pkill wlsunset",
        "tooltip": false
    },
    "disk": {
        "format": "σΑ΄ä {percentage_free}%",
        "path": "/"
    },
    "custom/updates": {
        "format": "σΑè½ {}",
        "exec": "checkupdates | wc -l",
        "interval": 3600,
        "signal": 8
    },
    "custom/weather": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/weather.sh",
        "interval": 3600,
        "tooltip": true,
        "tooltip-format": "{}",
        "on-click": "xdg-open https://wttr.in"
    },
    "custom/prayer": {
        "format": "νΜ™  {}",
        "exec": "~/.config/waybar/scripts/next-prayer.sh",
        "interval": 60,
        "tooltip": false
    },
    "sway/language": {
        "format": "σΑ¨™ {}"
    },
    "clock": {
        "format": "{:%a, %d %b %Y, %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "month",
            "on-scroll": 1,
            "format": {
                "months": "<span color='#ffead3'><b>{}</b></span>",
                "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
                "today": "<span color='#ff6699'><b>{}</b></span>"
            }
        }
    },
    "custom/power": {
        "format": " βèΜ ",
        "on-click": "~/.config/scripts/power-menu.sh",
        "tooltip": false
    },
    "tray": {
        "tray": {
        "icon-size": 16,
        "spacing": 10
        }
    }
}
