# This is the configuration file for Ghostty.
#
# This template file has been automatically created at the following
# path since Ghostty couldn't find any existing config files on your system:
#
#   $HOME/.config/ghostty/config
#

# Font Configuration
font-family = SpaceMono Nerd Font
font-style-italic = Victor Mono Italic
font-style-bold = SpaceMono Nerd Font Bold
font-style-bold-italic = Victor Mono Nerd Font Italic Bold
font-size = 14

# Window Configuration
window-save-state = never
# window-padding-x = 10
# window-padding-y = 10
window-decoration = false
# Custom color scheme
background = #141415
foreground = #cdcdcd

# 16-color palette
# Black (normal and bright)
palette = 0=#141415
palette = 8=#606079

# Red (normal and bright)
palette = 1=#d8647e
palette = 9=#d8647e

# Green (normal and bright)
palette = 2=#7fa563
palette = 10=#7fa563

# Yellow (normal and bright)
palette = 3=#f3be7c
palette = 11=#f3be7c

# Blue (normal and bright)
palette = 4=#7e98e8
palette = 12=#7e98e8

# Magenta (normal and bright)
palette = 5=#bb9dbd
palette = 13=#bb9dbd

# Cyan (normal and bright)
palette = 6=#b4d4cf
palette = 14=#b4d4cf

# White (normal and bright)
palette = 7=#cdcdcd
palette = 15=#cdcdcd

# Window settings
window-inherit-working-directory = true
window-theme = ghostty

# Transparency and Focus
background-opacity = 0.94
unfocused-split-opacity = 0.95

# Mouse Configuration
mouse-hide-while-typing = true

# Cursor Configuration
cursor-style = block
