# Font Configuration
font-family = SpaceMono Nerd Font
font-style-italic = Victor Mono Italic
font-style-bold = SpaceMono Nerd Font Bold
font-style-bold-italic = Victor Mono Nerd Font Italic Bold
font-size = 14

# Window Configuration
window-save-state = never
# window-padding-x = 10
# window-padding-y = 10
window-decoration = false
# Custom color scheme
# background = #141415
# foreground = #cdcdcd

# Window settings
window-inherit-working-directory = true
window-theme = ghostty

# Transparency and Focus
background-opacity = 1
unfocused-split-opacity = 1

# Mouse Configuration
mouse-hide-while-typing = true

# Cursor Configuration
cursor-style = block
